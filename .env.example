# ── Application ────────────────────────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
SECRET_KEY=change-me-to-a-long-random-secret-key

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_USER=escrapper
POSTGRES_PASSWORD=escrapper_secret
POSTGRES_DB=escrapper_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
DATABASE_URL=postgresql+asyncpg://escrapper:escrapper_secret@localhost:5433/escrapper_db

# ── Redis / Celery ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Celery Beat Schedule ───────────────────────────────────────────────────────
# Cron schedule for daily scraping (default: 6:00 AM IST = 00:30 UTC)
SCRAPE_CRON_HOUR=0
SCRAPE_CRON_MINUTE=30

# ── Scraper Settings ───────────────────────────────────────────────────────────
EPAPER_BASE_URL=https://epaper.dailythanthi.com
SCRAPER_HEADLESS=true
SCRAPER_TIMEOUT_MS=30000
SCRAPER_MAX_RETRIES=3
SCRAPER_BACKOFF_MULTIPLIER=2

# ── NLP Settings ───────────────────────────────────────────────────────────────
SUMMARY_MAX_SENTENCES=3
DEDUP_SIMILARITY_THRESHOLD=0.85

# ── CORS ───────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Frontend (Vite) ────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000/api
